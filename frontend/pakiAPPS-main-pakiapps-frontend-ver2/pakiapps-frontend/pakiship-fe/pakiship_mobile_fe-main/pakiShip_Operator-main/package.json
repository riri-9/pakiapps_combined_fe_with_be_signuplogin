{
  "name": "pakiship-operator",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "npm run test:unit",
    "test:unit": "jest --coverage --ci --passWithNoTests",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm test",
    "postinstall": "node ./scripts/ensure-detox-jest-compat.js",
    "detox:build": "detox build --configuration android.emu.debug",
    "detox:test": "detox test --configuration android.emu.debug --headless",
    "detox:build:ios": "detox build --configuration ios.sim.debug",
    "detox:test:ios": "detox test --configuration ios.sim.debug --cleanup"
  },
  "detox": {
    "testRunner": "jest",
    "runnerConfig": "tests/e2e/jest.config.js",
    "configurations": {
      "android.emu.debug": {
        "type": "android.emulator",
        "device": {
          "avdName": "Pixel_5_API_30"
        },
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "node ./scripts/detox-build-android.js"
      },
      "ios.sim.debug": {
        "type": "ios.simulator",
        "device": {
          "type": "iPhone 15"
        },
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/PakiShipOperator.app",
        "build": "node ./scripts/detox-build-ios.js"
      }
    }
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.0",
    "@expo-google-fonts/poppins": "^0.4.1",
    "@expo/ngrok": "^4.1.3",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.90.21",
    "expo": "~54.0.27",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.11",
    "expo-font": "~14.0.10",
    "expo-glass-effect": "~0.1.9",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.17",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "detox": "^16.5.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "typescript": "~5.9.2"
  }
}
