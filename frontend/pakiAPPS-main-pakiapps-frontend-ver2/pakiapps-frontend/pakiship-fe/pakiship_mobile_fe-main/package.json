{
  "name": "pakiship-mobile-workspace",
  "private": true,
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "setup": "npm install --legacy-peer-deps",
    "install:app": "npm install --legacy-peer-deps",
    "install:signup": "npm run install:app",
    "install:login": "npm install --prefix pakiShip_Login-main --legacy-peer-deps",
    "install:sender": "npm install --prefix pakiShip_Sender-main --legacy-peer-deps",
    "install:driver": "npm install --prefix pakiShip_Driver-main --legacy-peer-deps",
    "install:operator": "npm install --prefix pakiShip_Operator-main --legacy-peer-deps",
    "install:all": "npm run install:app && npm run install:login && npm run install:sender && npm run install:driver && npm run install:operator",
    "start": "node pakiShip_Signup-main/scripts/clear-tunnel.js && expo start",
    "start:signup": "npm run start",
    "start:login": "npm run start --prefix pakiShip_Login-main",
    "start:sender": "npm run start --prefix pakiShip_Sender-main",
    "start:driver": "npm run start --prefix pakiShip_Driver-main",
    "start:operator": "npm run start --prefix pakiShip_Operator-main",
    "dev": "node pakiShip_Signup-main/scripts/start-with-tunnel.js",
    "dev:signup": "npm run dev",
    "dev:login": "npm run dev --prefix pakiShip_Login-main",
    "dev:sender": "npm run dev --prefix pakiShip_Sender-main",
    "android": "expo run:android",
    "android:signup": "npm run android",
    "android:login": "npm run android --prefix pakiShip_Login-main",
    "android:sender": "npm run android --prefix pakiShip_Sender-main",
    "android:driver": "npm run android --prefix pakiShip_Driver-main",
    "android:operator": "npm run android --prefix pakiShip_Operator-main",
    "ios": "expo run:ios",
    "ios:signup": "npm run ios",
    "ios:login": "npm run ios --prefix pakiShip_Login-main",
    "ios:sender": "npm run ios --prefix pakiShip_Sender-main",
    "ios:driver": "npm run ios --prefix pakiShip_Driver-main",
    "ios:operator": "npm run ios --prefix pakiShip_Operator-main",
    "ngrok": "node pakiShip_Signup-main/scripts/clear-tunnel.js && expo start --tunnel",
    "web:operator": "npm run web --prefix pakiShip_Operator-main",
    "web:driver": "npm run web --prefix pakiShip_Driver-main",
    "test": "npm run test --prefix pakiShip_Signup-main",
    "test:signup": "npm run test --prefix pakiShip_Signup-main",
    "test:login": "npm run test --prefix pakiShip_Login-main",
    "test:sender": "npm run test --prefix pakiShip_Sender-main",
    "test:driver": "npm run test --prefix pakiShip_Driver-main",
    "test:operator": "npm run test --prefix pakiShip_Operator-main",
    "lint": "npm run lint --prefix pakiShip_Signup-main",
    "lint:signup": "npm run lint --prefix pakiShip_Signup-main",
    "lint:login": "npm run lint --prefix pakiShip_Login-main",
    "lint:sender": "npm run lint --prefix pakiShip_Sender-main",
    "lint:driver": "npm run lint --prefix pakiShip_Driver-main",
    "lint:operator": "npm run lint --prefix pakiShip_Operator-main",
    "verify": "npm run verify --prefix pakiShip_Signup-main",
    "verify:signup": "npm run verify --prefix pakiShip_Signup-main",
    "verify:login": "npm run verify --prefix pakiShip_Login-main",
    "verify:sender": "npm run verify --prefix pakiShip_Sender-main",
    "verify:driver": "npm run verify --prefix pakiShip_Driver-main",
    "verify:operator": "npm run verify --prefix pakiShip_Operator-main"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.2.0",
    "expo": "~54.0.0",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.7.0",
    "nativewind": "^2.0.11",
    "pakiship-mobile-workspace": "file:",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-refresh": "^0.18.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.1.10",
    "@types/react-native": "^0.72.8",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "concurrently": "^9.2.1",
    "detox": "^20.50.1",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "localtunnel": "^2.0.2",
    "postcss": "8.4.23",
    "tailwindcss": "3.3.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  }
}
