{
  "name": "template-repo-mb-single",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:prebuild": "expo prebuild --platform ios --non-interactive",
    "ios:build": "expo run:ios",
    "web": "expo start --web",
    "doctor": "npx expo-doctor",
    "postinstall": "node ./scripts/ensure-detox-jest-compat.js",
    "test": "npm run test:unit",
    "test:unit": "jest --coverage --ci --passWithNoTests",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm test && npm run doctor",
    "android:prebuild": "expo prebuild --platform android --non-interactive",
    "detox:build": "detox build --configuration android.emu.debug",
    "detox:test": "detox test --configuration android.emu.debug --headless",
    "detox:build:ios": "detox build --configuration ios.sim.debug",
    "detox:test:ios": "detox test --configuration ios.sim.debug --cleanup",
    "test:e2e": "npm run detox:test"
  },
  "detox": {
    "testRunner": "jest",
    "runnerConfig": "tests/e2e/jest.config.js",
    "configurations": {
      "android.emu.debug": {
        "type": "android.emulator",
        "device": {
          "avdName": "Pixel_5_API_30"
        },
        "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
        "build": "node ./scripts/detox-build-android.js"
      },
      "ios.sim.debug": {
        "type": "ios.simulator",
        "device": {
          "type": "iPhone 15"
        },
        "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/DetoxApp.app",
        "build": "node ./scripts/detox-build-ios.js"
      }
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/native-stack": "^7.3.25",
    "expo": "~54.0.33",
    "expo-build-properties": "^1.0.10",
    "expo-constants": "~18.0.9",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "~4.16.0"
  },
  "devDependencies": {
    "@types/jest": "~29.5.14",
    "@types/react": "~19.1.0",
    "detox": "^20.50.1",
    "eslint": "^9.39.3",
    "eslint-config-expo": "^10.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.17",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20"
  },
  "private": true
}
